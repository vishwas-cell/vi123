# MongoDB Connection URI
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio

# Email Configuration (Gmail requires app password, not regular password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password

# OpenAI API Key (For AI Chat Widget) - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server Configuration
PORT=5000

# CORS Configuration (Update with your frontend URL after deployment)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Environment
NODE_ENV=development
